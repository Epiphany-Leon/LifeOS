# Build artifacts
build/
DerivedData/
.build/

# Xcode user-specific files
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcuserstate
*.xccheckout
*.xcscmblueprint

# macOS files
.DS_Store

# SwiftData/Core Data local files
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Environment and local config
.env
.env.*
!.env.example
*.xcconfig.local
**/Secrets.xcconfig

# Credentials and signing files
*.p12
*.p8
*.cer
*.pem
*.key
*.mobileprovision
*.provisionprofile

# Local token/cache files
ai_api_token.txt

# Local release artifacts at repo root (built ZIPs and app bundles)
/release/

# Docs/ — only release/ and 开发日志/ are tracked; everything else is ignored
/Docs/*
!/Docs/release/
!/Docs/开发日志/
